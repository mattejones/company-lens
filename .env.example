# Database
POSTGRES_USER=company_lens
POSTGRES_PASSWORD=changeme

# Companies House API
# Register at https://developer.company-information.service.gov.uk/
CH_API_KEY=your_ch_api_key_here

# LLM Provider — openai | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_BASE_URL=https://api.openai.com/v1

# OpenAI reasoning effort — only applies to reasoning models (o3, o4-mini etc.)
# Values: low | medium | high | (leave empty for standard chat models)
LLM_REASONING_EFFORT=

# Required for openai provider, set to "ollama" if using local
OPENAI_API_KEY=your_openai_api_key_here
